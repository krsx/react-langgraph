# OpenRouter provider
LLM_PROVIDER_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=google/gemini-2.5-flash
OPENROUTER_API_KEY=your-openrouter-api-key

# Ollama provider (used when provider="ollama" in chat request)
# Point to the docker-compose service or an external Ollama instance
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen3.5:9b
# Optional alternative model (must support tool calling)
OLLAMA_OPTIONAL_MODEL=gpt-oss:20b

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=csagent
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=csagent

# LLM
LLM_MAX_TOKENS=4096