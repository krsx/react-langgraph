# OpenRouter provider
LLM_PROVIDER_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=google/gemini-2.5-flash
OPENROUTER_API_KEY=your-openrouter-api-key

# Ollama provider (used when provider="ollama" in chat request)
# Point to the docker-compose service or an external Ollama instance
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen3.5:9b
# Optional alternative model (must support tool calling)
OLLAMA_OPTIONAL_MODEL=gpt-oss:20b

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=csagent
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=csagent

# LLM
LLM_MAX_TOKENS=4096

# workspace-mcp / Workspace Agents (Google Calendar + Gmail)
# Required for Workspace Agent features (Calendar and Refund Email agents).
# Obtain OAuth client credentials from Google Cloud Console.
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
# Required for the one-time local OAuth setup (allows http://localhost callbacks).
# Set to 1 only when running workspace-mcp locally to obtain credentials.
# Do NOT set this to 1 in production deployments.
OAUTHLIB_INSECURE_TRANSPORT=1
# The authenticated Google account email — agents pass this to workspace-mcp tools so
# the MCP server uses the correct stored credentials instead of triggering a new OAuth flow.
WORKSPACE_USER_EMAIL=your-google-email@gmail.com

# Connect to an external streamable-http workspace-mcp server (takes priority over COMMAND).
# From Docker, use host.docker.internal to reach a server on your host machine.
# WORKSPACE_MCP_URL=http://host.docker.internal:8888/mcp
# Command used by McpClientManager to launch the workspace-mcp stdio subprocess.
WORKSPACE_MCP_COMMAND=workspace-mcp
# Space-separated arguments passed to WORKSPACE_MCP_COMMAND.
WORKSPACE_MCP_ARGS="--single-user --tool-tier core --permissions gmail:send calendar:full"
